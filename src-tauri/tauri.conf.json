      "endpoints": [
        "https://github.com/kaege35/EasyShare/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDUyRDNDN0M1MTdBOEU4OTgKUldTWTZLZ1h4Y2ZUVWxIQzZvUUwzaEcxZVRBMFNrV1RuT3ZzUjRVR1lXOERNMTJBRURRbUtadnYK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]

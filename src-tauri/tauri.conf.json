{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EasyShare",
  "version": "1.0.0",
  "identifier": "com.easyshare.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "EasyShare",
        "width": 1000,
        "height": 700,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://sizin-sunucunuz.com/update.json"
      ],
      "pubkey": "BURAYA_TARIH_ONCESI_ACIK_ANAHTAR_GELECEK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}

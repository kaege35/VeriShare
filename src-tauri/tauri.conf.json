{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EasyShare",
  "version": "1.0.0",
  "identifier": "com.easyshare.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
